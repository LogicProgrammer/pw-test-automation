{
  "compilerOptions": {
    // Type safety
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noUnusedLocals": false,
    "noUnusedParameters": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,

    // Target & module
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "esModuleInterop": true,

    // Output
    "sourceMap": true,
    "declaration": false, // true only if publishing a library

    // Performance
    "skipLibCheck": true, // skip type checks on node_modules .d.ts

    // Imports
    "baseUrl": ".",
    "paths": {
      "@test-setup": ["test-setup/base-test.ts"],
      "@playwright-utils": ["src/playwright"]
    },

    // Types — be explicit, not greedy
    "types": ["node", "@playwright/test"]
  },
  "include": ["src/**/*.ts", "tests/**/*.ts", "test-setup/**/*.ts", "playwright.config.ts"],
  "exclude": ["node_modules", "dist"]
}
